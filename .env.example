# ─────────────────────────────────────────────
#  Portfolio – Environment Variables Example
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Flask
FLASK_ENV=development
SECRET_KEY=change_this_to_a_long_random_string

# Admin panel password
ADMIN_PASSWORD=your_admin_password_here

# NVIDIA API (or any OpenAI-compatible LLM endpoint)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-4-scout-17b-16e-instruct

# Database (SQLite path — relative to project root)
DATABASE_URL=sqlite:///instance/portfolio.db

# (Optional) MySQL for production
# DATABASE_URL=mysql+pymysql://user:password@localhost/portfolio_db
